__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Tooling
toolbox.exe
toolbox

# ADK local session store
**/.adk/
*.db

